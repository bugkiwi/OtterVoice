  "type": "module",
  "description": "Web runtime adapter for OtterVoice: getUserMedia + MediaRecorder capture, HTMLAudioElement playback, fetch/WebSocket network.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
