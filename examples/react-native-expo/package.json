{
  "name": "@ottervoice/example-react-native-expo",
  "version": "0.2.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --go",
    "start:dev": "expo start --dev-client",
    "android": "expo start --go --android",
    "ios": "expo start --go --ios",
    "typecheck": "tsc --noEmit",
    "export": "expo export --platform all --output-dir dist",
    "prebuild": "expo prebuild",
    "build:ios:local": "expo run:ios",
    "build:android:local": "expo run:android",
    "build:simulator": "eas build --platform ios --profile development-simulator",
    "build:preview": "eas build --platform all --profile preview",
    "build:ios:simulator": "eas build --platform ios --profile preview-simulator",
    "build:android:preview": "eas build --platform android --profile preview"
  },
  "dependencies": {
    "@ottervoice/core": "workspace:*",
    "@ottervoice/provider-openrouter": "workspace:*",
    "@ottervoice/runtime-react-native": "workspace:*",
    "expo": "~57.0.4",
    "expo-audio": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-file-system": "~57.0.0",
    "expo-localization": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "typescript": "~6.0.3"
  }
}
