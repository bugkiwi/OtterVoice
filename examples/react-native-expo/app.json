{
  "expo": {
    "name": "OtterVoice Demo",
    "slug": "ottervoice-demo",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "ottervoice",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.ottervoice.demo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "io.ottervoice.demo",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow OtterVoice to hear you during a voice conversation."
        }
      ]
    ]
  }
}
