{
  "name": "ottervoice",
  "private": true,
  "version": "0.2.0-alpha.1",
  "type": "module",
  "description": "OtterVoice — a TypeScript-first, platform-agnostic SDK for real-time voice conversation (ASR + LLM + TTS).",
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:site": "bun run --cwd docs/site build",
    "test": "bun test",
    "test:smoke:audio-llm": "bun run --cwd examples/web test:audio-llm-smoke",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc -b",
    "verify:deploy": "bun run typecheck && bun test && bun run build && bun run build:site",
    "deploy:git": "bash scripts/deploy-via-git.sh",
    "publish:packages": "bun run scripts/publish-packages.ts",
    "publish:alpha": "bun run scripts/publish-packages.ts --tag alpha",
    "demo": "bun run examples/node-cli/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
