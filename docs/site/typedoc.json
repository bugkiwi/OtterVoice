{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "../../packages/core",
    "../../packages/runtime-web",
    "../../packages/runtime-react-native",
    "../../packages/runtime-node",
    "../../packages/protocol",
    "../../packages/provider-utils",
    "../../packages/provider-deepgram",
    "../../packages/provider-elevenlabs",
    "../../packages/provider-openrouter",
    "../../packages/provider-azure-speech"
  ],
  "entryPointStrategy": "packages",
  "plugin": ["typedoc-plugin-markdown"],
  "out": "./src/content/docs/en/reference/api",
  "readme": "none",
  "githubPages": false,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "skipErrorChecking": true,
  "disableSources": false,
  "hideGenerator": true,
  "sort": ["source-order"],
  "outputFileStrategy": "modules",
  "flattenOutputFiles": false,
  "entryFileName": "index.md",
  "publicPath": "/docs/en/reference/api/",
  "parametersFormat": "table",
  "propertiesFormat": "table",
  "enumMembersFormat": "table",
  "typeDeclarationFormat": "table",
  "indexFormat": "table",
  "useCodeBlocks": true,
  "expandObjects": true,
  "sanitizeComments": true
}
